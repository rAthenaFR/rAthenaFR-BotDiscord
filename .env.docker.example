# -----------------------------------------------------------------------------
# rAthenaFR Discord Bot - exemple Docker
# -----------------------------------------------------------------------------
# Copie ce fichier vers .env pour une exécution avec docker compose.
# Les noms d’hôtes ci-dessous supposent que le bot partage un réseau Docker avec rAthena.

DISCORD_TOKEN=replace_me
DISCORD_CLIENT_ID=replace_me
# Optionnel : si absent, DISCORD_CLIENT_ID est utilisé.
# DISCORD_APPLICATION_ID=replace_me
DISCORD_GUILD_ID=replace_me

# Nom affiché dans le footer des embeds Discord et dans les logs.
RATHENAFR_DISPLAY_NAME=rAthenaFR

RATHENAFR_STAFF_ROLE_IDS=
RATHENAFR_ADMIN_ROLE_IDS=
RATHENAFR_OWNER_ROLE_IDS=

# Écritures optionnelles dans la table login.
# Laisse false pour conserver le comportement historique en lecture seule.
RATHENAFR_ACCOUNT_CREATION_ENABLED=false
# Mode attendu par le serveur rAthena : plain ou md5.
RATHENAFR_ACCOUNT_PASSWORD_MODE=plain

RATHENAFR_DB_HOST=your-db-container
RATHENAFR_DB_PORT=3306
RATHENAFR_DB_NAME=ragnarok
RATHENAFR_DB_USER=rathenafr_bot
RATHENAFR_DB_PASSWORD=replace_me
RATHENAFR_DB_MAX_CONNECTIONS=5
RATHENAFR_DB_ACQUIRE_TIMEOUT_SECONDS=5

RATHENAFR_LOGIN_HOST=your-login-container
RATHENAFR_LOGIN_PORT=6900
RATHENAFR_CHAR_HOST=your-char-container
RATHENAFR_CHAR_PORT=6121
RATHENAFR_MAP_HOST=your-map-container
RATHENAFR_MAP_PORT=5121

# Images affichées par /search.
# RATHENAFR_ASSETS_BASE_URL doit être une URL publique accessible par Discord.
# N'utilise pas localhost/127.0.0.1 pour les embeds Discord.
# Exemple : https://panel.example.com ou http://90.23.70.10:8080
# Les chemins relatifs ci-dessous sont résolus depuis cette URL FluxCP.
# Les URLs absolues sont utilisées telles quelles et n'ont pas besoin de base_url.
# Monstres : garde le chemin FluxCP; le bot précharge la page du monstre pour générer le cache local.
RATHENAFR_ASSETS_BASE_URL=https://panel.example.com
RATHENAFR_ITEM_ICON_PATH=https://static.divine-pride.net/images/items/collection/{item_id}.png
RATHENAFR_MONSTER_IMAGE_PATH=data/monsters/{monster_id}.png
RATHENAFR_CHARACTER_IMAGE_PATH=https://static.divine-pride.net/images/jobs/{class_id}.png

# Variante 100% fichiers FluxCP si ton panel fournit ces assets localement.
# RATHENAFR_ITEM_ICON_PATH=data/items/images/{item_id}.png
# RATHENAFR_CHARACTER_IMAGE_PATH=data/jobs/images/{gender}/{class_id}.gif

RATHENAFR_HIDE_GM_CHARACTERS=false
RATHENAFR_HIDE_GM_FROM_TOP=true
RATHENAFR_HIDE_GM_GROUP_FROM_RANKING=60
RATHENAFR_DEFAULT_LIMIT=10
RATHENAFR_MAX_LIMIT=25
RATHENAFR_CACHE_ENABLED=true
RATHENAFR_CACHE_TTL_SECONDS=

RUST_LOG=rathenafr_discord_bot=info,info
