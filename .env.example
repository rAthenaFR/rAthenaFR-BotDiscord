# -----------------------------------------------------------------------------
# rAthenaFR Discord Bot - modèle de développement local
# -----------------------------------------------------------------------------
# Copiez ce fichier vers .env, puis remplacez les valeurs génériques.
# Ne committez jamais votre vrai fichier .env.
#
# RATHENAFR_DISCORD_BOT_ENV peut être défini dans l’environnement du processus
# avant le lancement pour charger un fichier .env situé ailleurs.
# Cette variable doit être fournie hors du fichier .env à charger.

# -----------------------------------------------------------------------------
# Discord
# -----------------------------------------------------------------------------

# Token du bot Discord.
DISCORD_TOKEN=remplacez_par_le_token_du_bot

# ID client/application Discord du bot.
DISCORD_CLIENT_ID=000000000000000000

# Optionnel : si cette variable est absente, DISCORD_CLIENT_ID est utilisé.
# DISCORD_APPLICATION_ID=000000000000000000

# ID du serveur Discord où les slash commands sont déployées.
DISCORD_GUILD_ID=000000000000000000

# Nom affiché dans le footer des embeds Discord et dans les logs.
RATHENAFR_DISPLAY_NAME=rAthenaFR

# -----------------------------------------------------------------------------
# Base de données rAthena
# -----------------------------------------------------------------------------

# Hôte MariaDB/MySQL. En local, utilisez 127.0.0.1 seulement si la base est
# exposée sur l’hôte.
RATHENAFR_DB_HOST=127.0.0.1
RATHENAFR_DB_PORT=3306
RATHENAFR_DB_NAME=ragnarok

# Utilisateur SQL du bot. Accordez SELECT par défaut, puis les droits optionnels
# documentés dans docs/DATABASE_FR.md selon les fonctionnalités activées.
RATHENAFR_DB_USER=rathenafr_bot

# Mot de passe de l’utilisateur SQL du bot.
RATHENAFR_DB_PASSWORD=remplacez_par_un_mot_de_passe

RATHENAFR_DB_MAX_CONNECTIONS=5
RATHENAFR_DB_ACQUIRE_TIMEOUT_SECONDS=5

# Vérifications des services rAthena utilisées par les commandes de statut.
# Ces adresses ne sont pas affichées dans Discord.
RATHENAFR_SERVER_HOST=127.0.0.1
RATHENAFR_LOGIN_PORT=6900
RATHENAFR_CHAR_PORT=6121
RATHENAFR_MAP_PORT=5121

# Overrides optionnels par service.
# RATHENAFR_LOGIN_HOST=127.0.0.1
# RATHENAFR_CHAR_HOST=127.0.0.1
# RATHENAFR_MAP_HOST=127.0.0.1

# -----------------------------------------------------------------------------
# Permissions et rôles
# -----------------------------------------------------------------------------

# IDs de rôles Discord séparés par des virgules.
# Laissez vide pour refuser les commandes associées au rôle.
RATHENAFR_HELPER_ROLE_IDS=
RATHENAFR_MODERATOR_ROLE_IDS=
RATHENAFR_GM_ROLE_IDS=
RATHENAFR_ADMIN_ROLE_IDS=
RATHENAFR_OWNER_ROLE_IDS=

# Compatibilité avec l’ancien rôle staff générique.
RATHENAFR_STAFF_ROLE_IDS=

# Variables héritées encore lues par compatibilité. Préférez les variables
# RATHENAFR_*_ROLE_IDS ci-dessus pour toute nouvelle configuration.
# DISCORD_STAFF_ROLE_IDS=
# DISCORD_ADMIN_ROLE_IDS=
# DISCORD_OWNER_ROLE_IDS=

# Rôles minimums attendus : helper, moderator, gm, admin ou owner.
RATHENAFR_GMMSG_MIN_ROLE=gm
RATHENAFR_DEBUG_MIN_ROLE=gm
RATHENAFR_AUDIT_MIN_ROLE=admin

# -----------------------------------------------------------------------------
# Logs staff
# -----------------------------------------------------------------------------

# Salon Discord utilisé pour les logs staff sensibles, dont gmmsg.
# Laissez vide pour journaliser uniquement côté serveur.
RATHENAFR_STAFF_LOG_CHANNEL_ID=

# -----------------------------------------------------------------------------
# Commandes publiques/staff
# -----------------------------------------------------------------------------

RATHENAFR_PUBLIC_PACK_ENABLED=true
RATHENAFR_STAFF_PACK_ENABLED=true

# Liste de commandes ou sous-commandes désactivées, séparées par des virgules.
# Exemple : staff inventory,top zeny
RATHENAFR_DISABLED_COMMANDS=

# Autorise l’affichage public de /online list.
RATHENAFR_ONLINE_LIST_PUBLIC=false

# Mode de /top zeny : enabled, anonymized ou disabled.
RATHENAFR_TOP_ZENY_MODE=enabled

# Limites d’affichage des commandes.
RATHENAFR_DEFAULT_LIMIT=10
RATHENAFR_MAX_LIMIT=25

# Masquage des personnages GM dans les réponses publiques.
RATHENAFR_HIDE_GM_CHARACTERS=false
RATHENAFR_HIDE_GM_FROM_TOP=true
RATHENAFR_HIDE_GM_GROUP_FROM_RANKING=60

# createaccount est conservée, mais la création publique reste désactivée par
# défaut. Mode de mot de passe attendu par rAthena : plain ou md5.
RATHENAFR_ACCOUNT_CREATION_ENABLED=false
RATHENAFR_ACCOUNT_PASSWORD_MODE=plain

# Gestion staff des comptes. Désactivée par défaut.
RATHENAFR_ACCOUNT_MANAGE_ENABLED=false
RATHENAFR_ACCOUNT_DELETE_ENABLED=false
RATHENAFR_ACCOUNT_MANAGE_MIN_ROLE=admin
RATHENAFR_ACCOUNT_DELETE_MIN_ROLE=owner

# -----------------------------------------------------------------------------
# Tables rAthena
# -----------------------------------------------------------------------------

# Tables utilisées pour les recherches item/mob : item_db ou item_db_re,
# mob_db ou mob_db_re.
RATHENAFR_ITEM_DB_TABLE=item_db
RATHENAFR_MOB_DB_TABLE=mob_db

# Active uniquement si les valeurs ci-dessous correspondent au battle_conf
# réellement chargé par le map-server. 100 = x1.
RATHENAFR_BATTLE_RATES_CONFIGURED=false
RATHENAFR_BATTLE_BASE_EXP_RATE=100
RATHENAFR_BATTLE_JOB_EXP_RATE=100
RATHENAFR_BATTLE_MVP_EXP_RATE=100
RATHENAFR_BATTLE_ITEM_RATE_COMMON=100
RATHENAFR_BATTLE_ITEM_RATE_COMMON_BOSS=100
RATHENAFR_BATTLE_ITEM_RATE_COMMON_MVP=100
RATHENAFR_BATTLE_ITEM_RATE_HEAL=100
RATHENAFR_BATTLE_ITEM_RATE_HEAL_BOSS=100
RATHENAFR_BATTLE_ITEM_RATE_HEAL_MVP=100
RATHENAFR_BATTLE_ITEM_RATE_USE=100
RATHENAFR_BATTLE_ITEM_RATE_USE_BOSS=100
RATHENAFR_BATTLE_ITEM_RATE_USE_MVP=100
RATHENAFR_BATTLE_ITEM_RATE_EQUIP=100
RATHENAFR_BATTLE_ITEM_RATE_EQUIP_BOSS=100
RATHENAFR_BATTLE_ITEM_RATE_EQUIP_MVP=100
RATHENAFR_BATTLE_ITEM_RATE_CARD=100
RATHENAFR_BATTLE_ITEM_RATE_CARD_BOSS=100
RATHENAFR_BATTLE_ITEM_RATE_CARD_MVP=100
RATHENAFR_BATTLE_ITEM_RATE_MVP=100
RATHENAFR_BATTLE_ITEM_DROP_COMMON_MIN=1
RATHENAFR_BATTLE_ITEM_DROP_COMMON_MAX=10000
RATHENAFR_BATTLE_ITEM_DROP_HEAL_MIN=1
RATHENAFR_BATTLE_ITEM_DROP_HEAL_MAX=10000
RATHENAFR_BATTLE_ITEM_DROP_USE_MIN=1
RATHENAFR_BATTLE_ITEM_DROP_USE_MAX=10000
RATHENAFR_BATTLE_ITEM_DROP_EQUIP_MIN=1
RATHENAFR_BATTLE_ITEM_DROP_EQUIP_MAX=10000
RATHENAFR_BATTLE_ITEM_DROP_CARD_MIN=1
RATHENAFR_BATTLE_ITEM_DROP_CARD_MAX=10000
RATHENAFR_BATTLE_ITEM_DROP_MVP_MIN=1
RATHENAFR_BATTLE_ITEM_DROP_MVP_MAX=10000
RATHENAFR_BATTLE_ITEM_LOGARITHMIC_DROPS=false
RATHENAFR_BATTLE_DROP_RATE_INCREASE=false
RATHENAFR_BATTLE_ITEM_RATIO_OVERRIDES=false

# -----------------------------------------------------------------------------
# gmmsg / GameBridge
# -----------------------------------------------------------------------------

# Mode d’envoi des messages en jeu.
# Valeurs disponibles :
# - disabled  : /gmmsg est déclaré mais aucun message n’est envoyé en jeu.
# - test      : /gmmsg valide les permissions et les logs sans dépendre de SQL.
# - sql_queue : /gmmsg insère le message dans `discord_gmmsg_queue`.
RATHENAFR_GMMSG_MODE=disabled
# RATHENAFR_GMMSG_MODE=test
# RATHENAFR_GMMSG_MODE=sql_queue

# Encodage des messages stockés dans `discord_gmmsg_queue.message`.
# windows1252 est recommandé pour le client Ragnarok Online.
# utf8 est réservé aux installations qui le supportent explicitement côté NPC/client.
RATHENAFR_GMMSG_ENCODING=windows1252

# Longueur maximale des messages gmmsg.
RATHENAFR_GMMSG_MAX_LENGTH=180

# -----------------------------------------------------------------------------
# Cache
# -----------------------------------------------------------------------------

# Cache mémoire court pour les commandes publiques en lecture seule.
# Laissez RATHENAFR_CACHE_TTL_SECONDS vide pour utiliser les valeurs par défaut.
RATHENAFR_CACHE_ENABLED=true
RATHENAFR_CACHE_TTL_SECONDS=

# -----------------------------------------------------------------------------
# Logs applicatifs
# -----------------------------------------------------------------------------

RUST_LOG=rathenafr_discord_bot=info,info

# -----------------------------------------------------------------------------
# Internationalisation / Locales
# -----------------------------------------------------------------------------

# Locale de secours pour les réponses du bot.
RATHENAFR_DEFAULT_LOCALE=fr-FR

# Locales préparées dans le dossier locales/.
RATHENAFR_SUPPORTED_LOCALES=fr-FR,en-US,es-ES,de-DE
