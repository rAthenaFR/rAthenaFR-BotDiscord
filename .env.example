# -----------------------------------------------------------------------------
# rAthenaFR Discord Bot - exemple de développement local
# -----------------------------------------------------------------------------
# Copie ce fichier vers .env et remplace toutes les valeurs replace_me.
# Ne commit jamais ton vrai fichier .env.

# Identifiants du bot Discord.
DISCORD_TOKEN=replace_me
DISCORD_CLIENT_ID=replace_me
DISCORD_GUILD_ID=replace_me

# Nom d’affichage local visible dans les embeds Discord et les logs.
RATHENAFR_DISPLAY_NAME=rAthenaFR

# Accès aux commandes réservées au staff.
# IDs de rôles Discord séparés par des virgules. Laisse vide pour refuser les commandes staff.
RATHENAFR_STAFF_ROLE_IDS=
RATHENAFR_ADMIN_ROLE_IDS=
RATHENAFR_OWNER_ROLE_IDS=

# Connexion à la base de données rAthenaFR ciblée.
# En local, utilise 127.0.0.1 seulement si MariaDB/MySQL est exposé sur l’hôte.
RATHENAFR_DB_HOST=127.0.0.1
RATHENAFR_DB_PORT=3306
RATHENAFR_DB_NAME=ragnarok
RATHENAFR_DB_USER=rathenafr_bot
RATHENAFR_DB_PASSWORD=replace_me
RATHENAFR_DB_MAX_CONNECTIONS=5
RATHENAFR_DB_ACQUIRE_TIMEOUT_SECONDS=5

# Vérifications des services rAthenaFR utilisées par /status.
# Ces adresses sont internes et ne sont pas affichées dans Discord.
RATHENAFR_SERVER_HOST=127.0.0.1
RATHENAFR_LOGIN_PORT=6900
RATHENAFR_CHAR_PORT=6121
RATHENAFR_MAP_PORT=5121

# Overrides optionnels par service.
# RATHENAFR_LOGIN_HOST=127.0.0.1
# RATHENAFR_CHAR_HOST=127.0.0.1
# RATHENAFR_MAP_HOST=127.0.0.1

# Affichage et confidentialité.
RATHENAFR_HIDE_GM_CHARACTERS=false
RATHENAFR_HIDE_GM_FROM_TOP=true
RATHENAFR_HIDE_GM_GROUP_FROM_RANKING=60
RATHENAFR_DEFAULT_LIMIT=10
RATHENAFR_MAX_LIMIT=25

# Cache mémoire local court pour les commandes publiques en lecture seule.
# Laisse RATHENAFR_CACHE_TTL_SECONDS vide pour utiliser les valeurs par défaut par commande.
RATHENAFR_CACHE_ENABLED=true
RATHENAFR_CACHE_TTL_SECONDS=

# Logs.
RUST_LOG=rathenafr_discord_bot=info,info
